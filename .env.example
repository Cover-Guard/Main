# =============================================================
# CoverGuard — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.
# =============================================================

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
# Project reference ID (used by Supabase CLI: supabase link --project-ref)
SUPABASE_PROJECT_REF=vxrckdzbwhufghadfnsc
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── Database connections ───────────────────────────────────────
# Supabase provides two connection endpoints; both are needed in production:
#
# 1. CONNECTION POOLER (pgBouncer) — used by the app at runtime for queries.
#    Found in: Supabase Dashboard → Project Settings → Database → Connection pooling
#    Transaction mode (port 6543) is recommended for serverless / stateless deployments.
#    Session mode (port 5432 on the pooler host) works for long-lived Node.js servers.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#
# 2. DIRECT CONNECTION — used by Prisma for migrations and schema introspection.
#    Found in: Supabase Dashboard → Project Settings → Database → Connection string (URI)
#    Never use this URL in the application server itself; it bypasses pgBouncer.
DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── API Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Local dev:  http://localhost:4000
# Production: https://api.coverguard.io
API_BASE_URL=http://localhost:4000

# JWT signing secret for session tokens (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-string

# CORS: comma-separated allowed origins
# Production: https://coverguard.io,https://www.coverguard.io
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://coverguard.io,https://www.coverguard.io

# ── Next.js / Web App ─────────────────────────────────────────
# Local dev:  http://localhost:4000
# Production: leave unset (same-origin — API runs in the same Vercel project)
NEXT_PUBLIC_API_URL=http://localhost:4000
# Local dev:  http://localhost:3000
# Production: https://coverguard.io
NEXT_PUBLIC_SITE_URL=https://coverguard.io
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Supabase Site URL — set this in the Supabase Dashboard under
# Auth → URL Configuration → Site URL, and add the following to Redirect URLs:
#   https://coverguard.io/**
#   https://www.coverguard.io/**
SUPABASE_SITE_URL=https://coverguard.io

# ── Google OAuth (for Supabase Auth) ─────────────────────────
# Configure in Google Cloud Console → APIs & Services → Credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── External Data Integrations ────────────────────────────────
# ATTOM Data Solutions — property data
ATTOM_API_KEY=

# Google Maps — property maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# FBI Crime Data Explorer — crime rate data (optional)
# Request a key at: https://api.data.gov/signup/
FBI_CDE_KEY=

# FEMA / flood data (public API — no key required, but rate-limited)
FEMA_API_BASE_URL=https://hazards.fema.gov/gis/nfhl/rest/services

# CoreLogic / LexisNexis CLUE (insurance history)
CORELOGIC_API_KEY=

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Deployment ────────────────────────────────────────────────
# Docker images are published to GitHub Container Registry (GHCR) on every
# push to main via the Build & Deploy workflow.
#   Web:  ghcr.io/cover-guard/main/web:<sha>
#   API:  ghcr.io/cover-guard/main/api:<sha>
#
# Add DEPLOY_WEBHOOK_URL to the GitHub "production" environment secret to
# trigger an automatic pull-and-restart on your hosting provider after each
# successful build.
DEPLOY_WEBHOOK_URL=

# ── Monitoring ────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
