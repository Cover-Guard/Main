# =============================================================
# CoverGuard — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.
# =============================================================

# ── Supabase ────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
# Project reference ID (used by Supabase CLI: supabase link --project-ref)
SUPABASE_PROJECT_REF=<your-project-ref>
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── Database connections ─────────────────────────────────────
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── API Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
API_BASE_URL=http://localhost:4000

# Note: JWT signing is handled entirely by Supabase Auth.
# This variable is not used by the API server and can be omitted.
# JWT_SECRET=

# CORS: comma-separated allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://coverguard.io,https://www.coverguard.io

# ── Next.js / Web App ───────────────────────────────────────
API_REWRITE_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=https://coverguard.io
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SITE_URL=https://coverguard.io

# ── Google OAuth (for Supabase Auth) ───────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── External Data Integrations ──────────────────────────────
RENTCAST_API_KEY=
ATTOM_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=
FBI_CDE_KEY=
WALK_SCORE_API_KEY=
FEMA_API_BASE_URL=https://hazards.fema.gov/gis/nfhl/rest/services
CORELOGIC_API_KEY=

# ── Anthropic (AI Advisor) ──────────────────────────────────
ANTHROPIC_API_KEY=

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Deployment ──────────────────────────────────────────────
DEPLOY_WEBHOOK_URL=

# ── Stripe (Subscription Billing) ───────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_INDIVIDUAL=price_xxx
STRIPE_PRICE_PROFESSIONAL=price_xxx
STRIPE_PRICE_TEAM=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_INDIVIDUAL=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PROFESSIONAL=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_TEAM=price_xxx

# ── Feature Flags ───────────────────────────────────────────
STRIPE_SUBSCRIPTION_REQUIRED=false

# ── Cache Sizing (optional — tune for your deployment) ──────
# Serverless (Vercel): use smaller values (500-2000).
# Long-lived Node.js servers can use larger values.
# CACHE_MAX_PROPERTIES=2000
# CACHE_MAX_RISK=2000
# CACHE_MAX_INSURANCE=2000
# CACHE_MAX_CARRIERS=1000
# CACHE_MAX_INSURABILITY=2000
# CACHE_MAX_PUBLIC_DATA=500
# CACHE_MAX_TOKENS=10000

# ── Monitoring ──────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
