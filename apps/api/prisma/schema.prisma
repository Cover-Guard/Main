// Prisma schema for CoverGuard
// Database: Supabase (PostgreSQL)
// Connection URL is configured via prisma.config.ts (Prisma 7+).
// See apps/api/prisma.config.ts — uses DIRECT_URL (non-pooled) for CLI operations
// and falls back to DATABASE_URL (pgBouncer-pooled) at runtime.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───────────────────────────────────────────────────────────────────
// Auth is handled by Supabase Auth; this table extends the auth.users record.

model User {
  id              String    @id @default(uuid()) // matches auth.users.id
  email           String    @unique
  firstName       String
  lastName        String
  role            UserRole  @default(BUYER)
  company         String?
  licenseNumber   String? // agents / lenders
  avatarUrl         String?
  stripeCustomerId  String?   @unique // Stripe customer ID
  termsAcceptedAt   DateTime? // null = has not yet accepted terms
  ndaAcceptedAt     DateTime? // set at registration when user agrees to NDA
  privacyAcceptedAt DateTime? // set at registration when user agrees to Privacy Policy
  createdAt         DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  savedProperties SavedProperty[]
  reports         PropertyReport[]
  checklists      PropertyChecklist[]
  clients         Client[]
  quoteRequests   QuoteRequest[]
  searchHistories SearchHistory[]
  subscriptions   Subscription[]
  deals           Deal[]
  usageCounters   UsageCounter[]
  activityEvents  UserActivityEvent[]

  @@index([role])
  @@map("users")
}

// ─── Usage Counters (free-tier hard limits) ──────────────────────────────────
// One row per (user, capability). Atomically incremented via the
// `enforce_free_usage_limit` Postgres function (defined in
// supabase/migrations/20260428000000_add_usage_counters.sql) so the API can
// check-and-increment in a single round trip.
//
// Free-tier caps live in apps/web/src/lib/plans.ts — keep in sync with the
// USAGE_LIMITS map in apps/api/src/middleware/usageLimit.ts.

model UsageCounter {
  userId     String
  capability String   // 'property_search' | 'ai_interaction'
  count      Int      @default(0)
  updatedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, capability])
  @@index([userId])
  @@map("usage_counters")
}

enum UserRole {
  BUYER
  AGENT
  LENDER
  INSURANCE
  ADMIN
}

// ─── Properties ───────────────────────────────────────────────────────────────

model Property {
  id             String       @id @default(uuid())
  address        String
  city           String
  state          String       @db.Char(2)
  zip            String       @db.VarChar(10)
  county         String
  lat            Float
  lng            Float
  propertyType   PropertyType @default(SINGLE_FAMILY)
  yearBuilt      Int?
  squareFeet     Int?
  bedrooms       Int?
  bathrooms      Float?
  lotSize        Float? // sq ft
  estimatedValue Int?
  lastSalePrice  Int?
  lastSaleDate   DateTime?
  parcelId       String?      @unique
  externalId     String?      @unique // ATTOM or other data provider id
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  riskProfile       RiskProfile?
  insuranceEstimate InsuranceEstimate?
  savedBy           SavedProperty[]
  reports           PropertyReport[]
  checklists        PropertyChecklist[]
  quoteRequests     QuoteRequest[]
  deals             Deal[]

  @@index([zip])
  @@index([state, city])
  @@index([lat, lng])
  @@index([state])
  @@index([createdAt])
  @@index([state, createdAt(sort: Desc)])
  @@map("properties")
}

enum PropertyType {
  SINGLE_FAMILY
  MULTI_FAMILY
  CONDO
  TOWNHOUSE
  MOBILE_HOME
  COMMERCIAL
  LAND
}

// ─── Risk Profile ─────────────────────────────────────────────────────────────

model RiskProfile {
  id               String    @id @default(uuid())
  propertyId       String    @unique
  overallRiskLevel RiskLevel @default(MODERATE)
  overallRiskScore Int // 0–100

  // Flood
  floodRiskLevel     RiskLevel @default(LOW)
  floodRiskScore     Int
  floodZone          String?
  floodFirmPanelId   String?
  floodBaseElevation Float?
  inSFHA             Boolean   @default(false)
  floodAnnualChance  Float?

  // Fire
  fireRiskLevel          RiskLevel @default(LOW)
  fireRiskScore          Int
  fireHazardZone         String?
  wildlandUrbanInterface Boolean   @default(false)
  nearestFireStation     Float? // miles

  // Wind
  windRiskLevel   RiskLevel @default(LOW)
  windRiskScore   Int
  designWindSpeed Int?
  hurricaneRisk   Boolean   @default(false)
  tornadoRisk     Boolean   @default(false)
  hailRisk        Boolean   @default(false)

  // Earthquake
  earthquakeRiskLevel RiskLevel @default(LOW)
  earthquakeRiskScore Int
  seismicZone         String?
  nearestFaultLine    Float? // miles

  // Crime
  crimeRiskLevel     RiskLevel @default(LOW)
  crimeRiskScore     Int
  violentCrimeIndex  Int
  propertyCrimeIndex Int
  nationalAvgDiff    Float // percentage diff

  generatedAt DateTime @default(now())
  expiresAt   DateTime

  // WalkScore
  walkScore              Int?
  walkScoreDescription   String?
  transitScore           Int?
  transitScoreDescription String?
  bikeScore              Int?
  bikeScoreDescription   String?
  walkScoreFetchedAt     DateTime?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([overallRiskLevel])
  @@map("risk_profiles")
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  VERY_HIGH
  EXTREME
}

// ─── Insurance Estimates ──────────────────────────────────────────────────────

model InsuranceEstimate {
  id                    String          @id @default(uuid())
  propertyId            String          @unique
  estimatedAnnualTotal  Int
  estimatedMonthlyTotal Int
  confidenceLevel       ConfidenceLevel @default(MEDIUM)
  homeownersLow         Int
  homeownersHigh        Int
  homeownersAvg         Int
  floodRequired         Boolean         @default(false)
  floodLow              Int?
  floodHigh             Int?
  floodAvg              Int?
  earthquakeRequired    Boolean         @default(false)
  earthquakeLow         Int?
  earthquakeHigh        Int?
  earthquakeAvg         Int?
  fireRequired          Boolean         @default(false)
  fireLow               Int?
  fireHigh              Int?
  fireAvg               Int?
  windRequired          Boolean         @default(false)
  windLow               Int?
  windHigh              Int?
  windAvg               Int?
  generatedAt           DateTime        @default(now())
  expiresAt             DateTime

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("insurance_estimates")
}

enum ConfidenceLevel {
  LOW
  MEDIUM
  HIGH
}

// ─── Saved Properties ─────────────────────────────────────────────────────────

model SavedProperty {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  clientId   String?  // optional: agent saves property on behalf of a client
  notes      String?
  tags       String[] @default([])
  savedAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@unique([userId, propertyId])
  @@index([userId, savedAt(sort: Desc)])
  @@index([propertyId])
  @@index([clientId])
  @@map("saved_properties")
}

// ─── Property Reports ─────────────────────────────────────────────────────────

model PropertyReport {
  id          String     @id @default(uuid())
  userId      String
  propertyId  String
  reportType  ReportType @default(FULL)
  pdfUrl      String?
  generatedAt DateTime   @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([userId, generatedAt(sort: Desc)])
  @@index([propertyId])
  @@map("property_reports")
}

enum ReportType {
  FULL
  RISK_SUMMARY
  INSURANCE_ESTIMATE
}

// ─── Clients (Agent → Client relationship) ────────────────────────────────────

model Client {
  id        String       @id @default(uuid())
  agentId   String
  firstName String
  lastName  String
  email     String
  phone     String?
  notes     String?
  status    ClientStatus @default(PROSPECT)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  agent           User            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  savedProperties SavedProperty[]
  deals           Deal[]

  @@index([agentId])
  @@map("clients")
}

enum ClientStatus {
  ACTIVE
  PROSPECT
  CLOSED
  INACTIVE
}

// ─── Quote Requests ───────────────────────────────────────────────────────────

model QuoteRequest {
  id            String             @id @default(uuid())
  userId        String
  propertyId    String
  carrierId     String
  coverageTypes String[]
  notes         String?
  status        QuoteRequestStatus @default(PENDING)
  submittedAt   DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([userId, submittedAt(sort: Desc)])
  @@index([propertyId, submittedAt(sort: Desc)])
  @@index([status])
  @@map("quote_requests")
}

enum QuoteRequestStatus {
  PENDING
  SENT
  RESPONDED
  DECLINED
}

// ─── Search History ───────────────────────────────────────────────────────────

model SearchHistory {
  id          String   @id @default(uuid())
  userId      String? // nullable for anonymous searches
  query       String
  resultCount Int      @default(0)
  searchedAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, searchedAt(sort: Desc)])
  @@index([searchedAt(sort: Desc)])
  @@map("search_history")
}

// ─── Subscriptions (Stripe) ──────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(uuid())
  userId               String
  stripeSubscriptionId String             @unique
  stripePriceId        String
  plan                 SubscriptionPlan   @default(INDIVIDUAL)
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([status])
  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

enum SubscriptionPlan {
  INDIVIDUAL
  PROFESSIONAL
  TEAM
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

// ─── Property Checklists ─────────────────────────────────────────────────────

model PropertyChecklist {
  id            String        @id @default(uuid())
  userId        String
  propertyId    String
  checklistType ChecklistType @default(INSPECTION)
  title         String
  items         Json          @default("[]") // ChecklistItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId, checklistType])
  @@index([userId, updatedAt(sort: Desc)])
  @@index([propertyId])
  @@map("property_checklists")
}

enum ChecklistType {
  INSPECTION
  NEW_BUYER
  AGENT
}

// ─── Deals (pipeline + fallout tracking) ─────────────────────────────────────

model Deal {
  id            String             @id @default(uuid())
  userId        String
  propertyId    String?
  clientId      String?
  title         String
  stage         DealStage          @default(PROSPECT)
  dealValue     Int? // USD — sale price / coverage value
  carrierName   String?
  falloutReason DealFalloutReason? // populated when stage = FELL_OUT
  falloutNotes  String?
  notes         String?
  openedAt      DateTime           @default(now())
  closedAt      DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([userId, stage])
  @@index([userId, closedAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([propertyId])
  @@index([clientId])
  @@index([falloutReason])
  @@map("deals")
}

enum DealStage {
  PROSPECT
  IN_PROGRESS
  UNDER_CONTRACT
  CLOSED_WON
  FELL_OUT
}

enum DealFalloutReason {
  INSURABILITY
  PRICING_TOO_HIGH
  CARRIER_DECLINED
  CLIENT_BACKED_OUT
  INSPECTION_ISSUES
  FINANCING_FELL_THROUGH
  APPRAISAL_LOW
  TITLE_ISSUES
  COMPETING_OFFER
  PROPERTY_CONDITION
  OTHER
}


// ─── User Activity Events ────────────────────────────────────────────────────
// Append-only product-analytics activity log for "everything user X did".
//
// Distinct from packages/shared/src/utils/auditTrail.ts, which is the *
// regulatory* loan-file audit trail (hash-chained, signed, retention-bound).
// Both coexist on purpose:
//
//   - auditTrail entries: only loan-file actions (regulated reports, LOS
//     connection lifecycle). Tamper-evident chain. Compliance artifact.
//   - UserActivityEvent: every meaningful user action across the product
//     (property views, searches, profile updates, etc.). No chain integrity.
//
// Handlers writing a regulated audit_trail entry SHOULD also write a matching
// UserActivityEvent with entityType = 'audit_trail' and entityId = the audit
// entry id, so the activity feed can deep-link to the regulated entry.

model UserActivityEvent {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String
  eventType  ActivityEventType
  entityType String? // 'property' | 'report' | 'quote_request' | 'audit_trail' | ...
  entityId   String?
  metadata   Json              @default("{}")
  ipAddress  String?           @db.Inet
  userAgent  String?
  occurredAt DateTime          @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt(sort: Desc)])
  @@index([eventType, occurredAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("user_activity_events")
}

enum ActivityEventType {
  LOGIN
  LOGOUT
  SIGNUP
  PROFILE_UPDATED
  CONSENT_ACCEPTED
  PROPERTY_VIEWED
  PROPERTY_SAVED
  PROPERTY_UNSAVED
  SEARCH_PERFORMED
  REPORT_GENERATED
  REPORT_DOWNLOADED
  QUOTE_REQUESTED
  QUOTE_STATUS_CHANGED
  CHECKLIST_CREATED
  CHECKLIST_UPDATED
  AGENT_CHAT_SENT
  DIRECT_MESSAGE_SENT
  NOTIFICATION_READ
  SUBSCRIPTION_CHANGED
  ADMIN_ACTION

  @@map("activity_event_type")
}
