          }, {
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.safeJson();",
                "if (!json) { pm.test('JSON response', () => pm.expect.fail('Non-JSON')); return; }",
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "pm.test('success is true', () => pm.expect(json.success).to.be.true);",
                "pm.test('Has property id', () => pm.expect(json.data).to.have.property('id'));"
              ]
            }
          }]
        },
        {
          "name": "Property Not Found (expect 404)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/properties/nonexistent-id-99999", "host": ["{{base_url}}"], "path": ["api", "properties", "nonexistent-id-99999"] },
