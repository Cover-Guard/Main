{
  "info": {
    "name": "CoverGuard API",
    "description": "Complete API verification suite for CoverGuard (coverguard.io).\n\n## Setup\n1. Set the `base_url` variable (default: https://api.coverguard.io)\n2. Set `access_token` from your Supabase session (DevTools → Application → Local Storage)\n3. Run the **Health** request first, then **Search** to auto-populate `property_id`\n4. Run the full collection with Collection Runner",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://api.coverguard.io", "type": "string" },
    { "key": "web_url", "value": "https://coverguard.io", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "property_id", "value": "", "type": "string" },
    { "key": "client_id", "value": "", "type": "string" },
    { "key": "checklist_id", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "1 — Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] },
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "pm.test('Body has status ok', () => {",
                "  const json = pm.response.json();",
                "  pm.expect(json.status).to.eql('ok');",
                "});"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "2 — Properties (Public)",
      "item": [
        {
          "name": "Suggest",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/properties/suggest?q=miami&limit=5",
              "host": ["{{base_url}}"], "path": ["api", "properties", "suggest"],
              "query": [
                { "key": "q", "value": "miami" },
                { "key": "limit", "value": "5" }
              ]
            },
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "pm.test('success is true', () => pm.expect(pm.response.json().success).to.be.true);"
              ]
            }
          }]
        },
        {
          "name": "Search by ZIP",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/properties/search?address=90210",
              "host": ["{{base_url}}"], "path": ["api", "properties", "search"],
              "query": [{ "key": "address", "value": "90210" }]
            },
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "pm.test('success is true', () => pm.expect(pm.response.json().success).to.be.true);",
                "",
                "// Auto-set property_id for downstream requests",
                "const json = pm.response.json();",
                "const props = json.data?.properties || json.data?.results || [];",
                "if (props.length > 0 && props[0].id) {",
                "  pm.collectionVariables.set('property_id', props[0].id);",
                "  console.log('Set property_id =', props[0].id);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Search by City/State",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/properties/search?city=Miami&state=FL",
              "host": ["{{base_url}}"], "path": ["api", "properties", "search"],
              "query": [
                { "key": "city", "value": "Miami" },
                { "key": "state", "value": "FL" }
              ]
            },
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "pm.test('success is true', () => pm.expect(pm.response.json().success).to.be.true);"
              ]
            }
          }]
        },
        {
          "name": "Search — missing params (expect 400)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/properties/search", "host": ["{{base_url}}"], "path": ["api", "properties", "search"] },
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                "pm.test('success is false', () => pm.expect(pm.response.json().success).to.be.false);"
              ]
            }
          }]
        },
        {
          "name": "Property Detail",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/properties/{{property_id}}", "host": ["{{base_url}}"], "path": ["api", "properties", "{{property_id}}"] },
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "pm.test('success is true', () => pm.expect(pm.response.json().success).to.be.true);",
                "pm.test('Has property data', () => pm.expect(pm.response.json().data).to.have.property('id'));"
              ]
            }
          }]
        },
        {
          "name": "Property Not Found (expect 404)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/properties/nonexistent-id-99999", "host": ["{{base_url}}"], "path": ["api", "properties", "nonexistent-id-99999"] },
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 404', () => pm.response.to.have.status(404));",
                "pm.test('success is false', () => pm.expect(pm.response.json().success).to.be.false);"
              ]
            }
          }]
        }
      ]
    },
