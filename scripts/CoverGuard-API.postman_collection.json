{
  "info": {
    "name": "CoverGuard API",
    "description": "Complete API verification suite for CoverGuard (coverguard.io).\n\n## Setup\n1. Set `base_url` — try `https://api.coverguard.io` first; if you get DEPLOYMENT_NOT_FOUND, switch to `https://coverguard.io`\n2. Set `access_token` from your Supabase session (DevTools → Application → Local Storage)\n3. Run the **Health** request first, then **Search** to auto-populate `property_id`\n4. Run the full collection with Collection Runner (200ms delay)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://coverguard.io", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "property_id", "value": "", "type": "string" },
    { "key": "client_id", "value": "", "type": "string" },
    { "key": "checklist_id", "value": "", "type": "string" },
    { "key": "vercel_bypass_secret", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Add Vercel Protection Bypass header if secret is configured",
          "const bypass = pm.collectionVariables.get('vercel_bypass_secret');",
          "if (bypass) {",
          "  pm.request.headers.add({ key: 'x-vercel-protection-bypass', value: bypass });",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [
          "// Shared helper: detect Vercel infrastructure errors before any test runs",
          "const body = pm.response.text();",
          "const isVercelError = body.includes('DEPLOYMENT_NOT_FOUND') || body.includes('NOT_FOUND') && !body.startsWith('{');",
          "if (isVercelError) {",
          "  pm.test('Vercel deployment reachable', () => {",
          "    pm.expect.fail('Got Vercel DEPLOYMENT_NOT_FOUND — check base_url variable or redeploy the API project on Vercel');",
          "  });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "0 — Connectivity Check",
      "item": [
        {
          "name": "API reachable?",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] },
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const body = pm.response.text();",
                "",
                "if (pm.response.code === 404 && !body.startsWith('{')) {",
                "  console.error('DEPLOYMENT_NOT_FOUND — try switching base_url:');",
                "  console.error('  Option A: https://coverguard.io');",
                "  console.error('  Option B: https://api.coverguard.io');",
                "  console.error('  Option C: Set vercel_bypass_secret variable');",
                "  pm.test('API deployment exists', () => pm.expect.fail(",
                "    'Vercel returned DEPLOYMENT_NOT_FOUND. The API is not deployed at ' + pm.collectionVariables.get('base_url') + '. See console for options.'",
                "  ));",
                "  return;",
                "}",
                "",
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "",
                "try {",
                "  const json = pm.response.json();",
                "  pm.test('Body has status ok', () => pm.expect(json.status).to.eql('ok'));",
                "} catch (e) {",
                "  pm.test('Response is valid JSON', () => pm.expect.fail('Non-JSON response: ' + body.substring(0, 100)));",
                "}"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "1 — Properties (Public)",
      "item": [
        {
          "name": "Suggest",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/properties/suggest?q=miami&limit=5",
              "host": ["{{base_url}}"], "path": ["api", "properties", "suggest"],
              "query": [
                { "key": "q", "value": "miami" },
                { "key": "limit", "value": "5" }
              ]
            },
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
