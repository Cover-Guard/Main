                "pm.test('success is true', () => pm.expect(json.success).to.be.true);",
                "",
                "const props = json.data?.properties || json.data?.results || [];",
                "if (props.length > 0 && props[0].id) {",
                "  pm.collectionVariables.set('property_id', props[0].id);",
                "  console.log('Set property_id =', props[0].id);",
                "} else {",
