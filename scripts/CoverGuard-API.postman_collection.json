{
  "info": {
    "name": "CoverGuard API",
    "description": "Complete API verification suite for CoverGuard.\n\n## Setup\n1. Set `base_url` to `https://api.coverguard.io` (direct) or `https://coverguard.io` (web proxy)\n2. Set `access_token` from your Supabase session (DevTools → Application → Local Storage → Supabase auth key → access_token)\n3. Run **0 — Connectivity Check** first, then **Search by ZIP** to auto-populate `property_id`\n4. Run the full collection with Collection Runner (200ms delay)\n\n## Variables auto-populated by tests\n- `property_id` — set by Search by ZIP\n- `client_id` — set by Create Client\n- `checklist_id` — set by Create Checklist\n- `quote_request_id` — set by Create Quote Request",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://api.coverguard.io", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "property_id", "value": "", "type": "string" },
    { "key": "client_id", "value": "", "type": "string" },
    { "key": "checklist_id", "value": "", "type": "string" },
    { "key": "quote_request_id", "value": "", "type": "string" },
    { "key": "vercel_bypass_secret", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "const bypass = pm.collectionVariables.get('vercel_bypass_secret');",
          "if (bypass) {",
          "  pm.request.headers.add({ key: 'x-vercel-protection-bypass', value: bypass });",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [
          "// Detect Vercel infrastructure errors",
          "const body = pm.response.text();",
          "if (pm.response.code === 404 && !body.startsWith('{')) {",
          "  if (body.includes('DEPLOYMENT_NOT_FOUND')) {",
          "    pm.test('Vercel deployment reachable', () => pm.expect.fail(",
          "      'DEPLOYMENT_NOT_FOUND — check base_url or redeploy the API project'",
          "    ));",
          "  }",
          "}",
          "",
          "// Helper: safe JSON parse (avoids crash on HTML error pages)",
          "pm.safeJson = () => { try { return pm.response.json(); } catch(e) { return null; } };"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "0 — Connectivity",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] },
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.safeJson();",
                "if (!json) {",
                "  pm.test('Response is JSON (not HTML)', () => pm.expect.fail(",
                "    'Got non-JSON response. body: ' + pm.response.text().substring(0, 150)",
                "  ));",
                "  return;",
                "}",
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "pm.test('status is ok', () => pm.expect(json.status).to.eql('ok'));"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "1 — Properties (Public)",
      "item": [
        {
          "name": "Suggest",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/properties/suggest?q=miami&limit=5",
              "host": ["{{base_url}}"], "path": ["api", "properties", "suggest"],
              "query": [
                { "key": "q", "value": "miami" },
                { "key": "limit", "value": "5" }
              ]
            },
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.safeJson();",
                "if (!json) { pm.test('JSON response', () => pm.expect.fail('Non-JSON')); return; }",
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "pm.test('success is true', () => pm.expect(json.success).to.be.true);",
                "pm.test('data is array', () => pm.expect(json.data).to.be.an('array'));"
              ]
            }
          }]
        },
        {
          "name": "Search by ZIP",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/properties/search?address=90210",
