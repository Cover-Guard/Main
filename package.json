{
  "name": "coverguard",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "dev:all": "turbo run dev",
    "build": "next build",
    "test": "turbo run test -- --passWithNoTests",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "turbo run db:migrate --filter=@coverguard/api",
    "db:seed": "turbo run db:seed --filter=@coverguard/api",
    "db:studio": "turbo run db:studio --filter=@coverguard/api",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean",
    "qa:env": "npx tsx scripts/qa/env-validate.ts",
    "qa:health": "npx tsx scripts/qa/health-check.ts",
    "qa:smoke": "npx tsx scripts/qa/smoke-test.ts"
  },
  "dependencies": {
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "autoprefixer": "^10.4.20",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "prettier": "^3.4.2",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "dotenv": "^16.4.7"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.0"
}
