{
  "version": 2,
  "github": {
    "enabled": false
  },
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next",
      "config": {
        "zeroConfig": true
      }
    },
    {
      "src": "apps/api/package.json",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api(.*)",
      "dest": "apps/api"
    },
    {
      "src": "/(.*)",
      "dest": "apps/web"
    }
  ]
}
